#####This XML file defines the visual geometry (0.05m sphere) and spatial frame (boulder_link) of the simulated rock.####

<?xml version="1.0"?>
<robot name="lunar_boulder">
  <link name="boulder_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.05"/>
      </geometry>
      <material name="grey">
        <color rgba="0.5 0.5 0.5 1"/>
      </material>
    </visual>
  </link>
</robot>
